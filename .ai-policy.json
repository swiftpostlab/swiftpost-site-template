{
  "protectedFiles": [
    "*.env",
    "*.env.*",
    "*.pem",
    "*.key",
    "*.pub",
    "credentials.json",
    "secrets/",
    "internal-config.yml"
  ],
  "excludedFiles": [
    "**/node_modules/",
    "**/.next/",
    "dist/",
    "build/",
    "out/",
    "*.log",
    "*.tmp",
    "*.bak",
    "tmp/",
    "temp/",
    "logs/",
    ".turbo/"
  ],
  "terminalAutoApprove": {
    "/^git (log|status).*$/": true,
    "/^yarn (lint|lint:ci|typecheck|typecheck:ci|sync:ai|sync:ai:import)$/": true,
    "/^yarn turbo (lint|typecheck) --ui stream$/": true,
    "/^node --experimental-strip-types scripts/sync-ai-ignores\\.mts$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "yarn install": true,
    "yarn install --network-timeout 100000": true,
    "rm": false,
    "rmdir": false,
    "del": false,
    "curl": false,
    "wget": false,
    "/^yarn (lint|lint:ci|typecheck|typecheck:ci|sync:ai)$/": true
  },
  "editAutoApprove": {
    "**/*.{ts,tsx,js,mjs,mts,json,yml,yaml,css,md}": true,
    "**/.env*": false,
    "**/secrets/**": false,
    "**/.aiexclude": false,
    "**/.ai-policy.json": false,
    "**/*.{pem,key,pub}": false,
    "**/internal-config.yml": false
  }
}
