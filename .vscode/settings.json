{
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": "always",
    "source.fixAll.eslint": "always"
  },
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "json.format.enable": true,
  "typescript.tsdk": "./node_modules/typescript/lib",
  "cSpell.words": [
    "Klarna",
    "swiftpost"
  ],
  "chat.tools.terminal.autoApprove": {
    "/^git (log|status).*$/": true,
    "/^yarn (lint|lint:ci|typecheck|typecheck:ci|sync:ai)$/": true,
    "/^yarn turbo (lint|typecheck) --ui stream$/": true,
    "/^node --experimental-strip-types scripts/sync-ai-ignores\\.mts$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "yarn install": true,
    "yarn install --network-timeout 100000": true,
    "rm": false,
    "rmdir": false,
    "del": false,
    "curl": false,
    "wget": false,
    "/^yarn (lint|lint:ci|typecheck|typecheck:ci|sync:ai|sync:ai:import)$/": true
  },
  "files.associations": {
    "*.env": "copilot-restricted-file",
    "*.env.*": "copilot-restricted-file",
    "*.pem": "copilot-restricted-file",
    "*.key": "copilot-restricted-file",
    "*.pub": "copilot-restricted-file",
    "credentials.json": "copilot-restricted-file",
    "secrets/": "copilot-restricted-file",
    "internal-config.yml": "copilot-restricted-file"
  },
  "github.copilot.enable": {
    "copilot-restricted-file": false
  },
  "chat.tools.edits.autoApprove": {
    "**/*.{ts,tsx,js,mjs,mts,json,yml,yaml,css,md}": true,
    "**/.env*": false,
    "**/secrets/**": false,
    "**/.aiexclude": false,
    "**/.ai-policy.json": false,
    "**/*.{pem,key,pub}": false,
    "**/internal-config.yml": false
  }
}
